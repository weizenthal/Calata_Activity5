@{
    ViewData["Title"] = "Home Page";
}

<link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@700&display=swap" rel="stylesheet">

<style>
    body {
        background-color: #f8bbd0; 
    }

    .main-container {
        display: flex;
        width: 100%;
        max-width: 1100px;
        background: white;
        border-radius: 30px;
        overflow: hidden;
        margin: 40px auto;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.1);
    }

    .grid-wrapper {
        flex: 1.2;
        background-color: #fce4ec;
        padding: 30px;
        display: flex;
        align-items: center;
    }

    .photo-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 15px;
        width: 100%;
    }

    .photo-box {
        aspect-ratio: 1 / 1;
        overflow: hidden;
        border-radius: 15px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }

    .photo-box img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .photo-box img:hover {
        transform: scale(1.08);
    }

    .info-wrapper {
        flex: 1;
        padding: 60px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    h1 {
        color: #ff66aa;
        font-family: 'Dancing Script', cursive; 
        font-size: 4rem;
        margin-bottom: 15px;
    }

    .bio-text {
        color: #555;
        line-height: 1.8;
        font-size: 1.1rem;
        margin-bottom: 25px;
    }

    .manifest-text {
        font-style: italic;
        color: #d81b60;
        font-weight: 500;
        border-left: 3px solid #ff66aa;
        padding-left: 15px;
        margin-bottom: 30px;
    }

    .contact-btn {
        display: inline-block;
        padding: 12px 35px;
        background-color: #ff66aa;
        color: white;
        text-decoration: none;
        border-radius: 50px;
        font-weight: bold;
        transition: all 0.3s ease;
        width: fit-content;
    }

    .contact-btn:hover {
        background-color: #d81b60;
        transform: translateY(-2px);
    }

    @@media (max-width: 992px) {
        .main-container {
            flex-direction: column-reverse;
            margin: 10px auto;
        }
        .info-wrapper {
            padding: 40px 20px;
            text-align: center;
        }
        .contact-btn {
            margin: 0 auto;
        }
    }
</style>

<div class="main-container">
    <div class="grid-wrapper">
        <div class="photo-grid">
            <div class="photo-box"><img src="/one.jpg" alt="Bia 1"></div>
            <div class="photo-box"><img src="/two.jpg" alt="Bia 2"></div>
            <div class="photo-box"><img src="/three.jpg" alt="Bia 3"></div>
            <div class="photo-box"><img src="/four.jpg" alt="Bia 4"></div>
        </div>
    </div>

    <div class="info-wrapper">
        <h1>Hello! I am Bia</h1>
        
        <div class="bio-text">
            I’m a dedicated working student and a full-time furrmom to my beloved cats (though one of them is quite camera-shy!). 
            I have a deep love for exploring new places, trying out unique activities, and traveling to see what the world has to offer.
        </div>

        <div class="manifest-text">
            Currently manifesting a life of peace and happiness—settling down in Australia, achieving career success, 
            and gaining the financial freedom to attend every BTS and Seventeen concert. AMEN ✨
        </div>

        <a href="#" class="contact-btn">Let's Be Friends!</a>
    </div>
</div>