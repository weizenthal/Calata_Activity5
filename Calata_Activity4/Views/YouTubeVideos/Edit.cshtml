@model Calata_Activity4.Models.YouTubeVideo

@{
    ViewData["Title"] = "Modify Video Log";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 mx-auto" style="max-width: 600px;">
        <div class="card-body p-4">
            <h3 class="fw-bold text-dark mb-3">Edit Video Log</h3>
            <hr />
            <form asp-action="Edit">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label asp-for="Title" class="form-label fw-semibold"></label>
                    <input asp-for="Title" class="form-control" required />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="VideoUrl" class="form-label fw-semibold">YouTube URL</label>
                    <input asp-for="VideoUrl" class="form-control" type="url" required />
                    <span asp-validation-for="VideoUrl" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Category" class="form-label fw-semibold"></label>
                    <select asp-for="Category" class="form-select" required>
                        <option value="BTS">BTS</option>
                        <option value="SVT">SVT (Seventeen)</option>
                        <option value="Others">Others</option>
                    </select>
                    <span asp-validation-for="Category" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2 justify-content-end mt-4">
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary px-4 fw-bold">Update Entry</button>
                </div>
            </form>
        </div>
    </div>
</div>